---
import YouTubeEmbed from '../YouTubeEmbed.astro';
const { title, sub_title, years, details, youtubeId, alignRight, stretchCards, rowSpan } = Astro.props;
---

<li class={`relative group p-6 bg-background-offset/80 backdrop-blur-md shadow-lg rounded-2xl border border-border hover:border-primary transition-all duration-300 hover:shadow-[0_0_20px_rgba(125,132,113,0.3)] hover:-translate-y-1 overflow-hidden flex flex-col ${stretchCards ? 'h-full' : 'h-fit'} ${alignRight ? 'lg:col-start-2' : ''} ${rowSpan === 2 ? 'lg:row-span-2' : ''}`}>
  <div class="absolute -top-10 -right-10 w-32 h-32 bg-primary/10 blur-[50px] rounded-full group-hover:bg-primary/20 transition-colors pointer-events-none"></div>
  <div class="flex flex-col sm:flex-row justify-between items-start relative z-10">
    <div class="mb-4 sm:mb-0">
      <h3 class="text-2xl font-bold tracking-tight text-default">{title}</h3>
      <p class="text-lg font-medium text-primary pt-2">{sub_title}</p>
    </div>
    <p class="text-sm font-mono text-offset sm:text-right whitespace-nowrap bg-background px-3 py-1 rounded-full border border-border">{years}</p>
  </div>
  {details && (
    <ul class="mt-4 space-y-2">
      {details.split('\n').filter((line: string) => line.trim()).map((line: string) => (
        <li class="flex items-start gap-2 text-offset leading-relaxed">
          <span class="text-primary mt-1.5 shrink-0">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </span>
          <span>{line.replace(/^[•\-\*]\s*/, '').trim()}</span>
        </li>
      ))}
    </ul>
  )}
  {youtubeId && (
    <div class="mt-6">
      <YouTubeEmbed id={youtubeId} title={title} />
    </div>
  )}
</li>
