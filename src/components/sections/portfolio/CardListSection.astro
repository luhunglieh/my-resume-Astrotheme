---
import CardListItem from './CardListItem.astro';

interface Item {
  title: string;
  sub_title: string;
  years: string;
  details?: string;
  youtubeId?: string;
  alignRight?: boolean;
  rowSpan?: number;
}

const { title, items, stretchCards = false } = Astro.props;
---

<section class="py-14 bg-background">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl lg:text-4xl font-semibold text-center mb-12">
        {title}
    </h2>

    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {items.map((item: Item) => (
        <CardListItem
          title={item.title}
          sub_title={item.sub_title}
          years={item.years}
          details={item?.details}
          youtubeId={item?.youtubeId}
          alignRight={item?.alignRight}
          stretchCards={stretchCards}
          rowSpan={item?.rowSpan}
        />
      ))}
    </ul>
  </div>
</section>
